rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write to their own documents
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // AI Cache is strictly backend-only (read/write happens via Firebase Admin in serverless functions).
    // The client should NEVER have direct access to the cache collection.
    match /ai-cache/{document=**} {
      allow read, write: if false; 
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
